# Backend base URL (templates-workflow-BE). /api is appended automatically.
# Local: http://localhost:8000 (or the port your BE runs on)
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- GrowStack-style API (same as curl: testing.growstack.ai/users/api/v1/integrationHub/...) ---
# When set, integration-hub requests go here with optional Bearer token (same shape as GrowStack).
# NEXT_PUBLIC_GROWSTACK_USERS_URL=https://testing.growstack.ai/users
# NEXT_PUBLIC_GROWSTACK_AUTH_TOKEN=your_jwt_bearer_token

# OAuth connect base: where "Connect" opens (e.g. GrowStack). Popup will load {base}/orchestration/{service}/connect → Google sign-in.
# Set to https://testing.growstack.ai to get the same Google "Sign in to GrowstackAI Automation" popup.
# NEXT_PUBLIC_OAUTH_CONNECT_BASE_URL=https://testing.growstack.ai
# Fallback if above unset:
# NEXT_PUBLIC_CONNECT_BASE_URL=http://localhost:8000
